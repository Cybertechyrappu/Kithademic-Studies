rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public read access for courses
    match /courses/{courseId} {
      allow read: if true;  // Anyone can read courses
      allow write: if false;  // Only admins via Firebase Console

      // Public read access for lessons within courses
      match /lessons/{lessonId} {
        allow read: if true;  // Anyone can read lessons
        allow write: if false;  // Only admins via Firebase Console
      }
    }

    // Public read access for basic videos
    match /basicVideos/{videoId} {
      allow read: if true;  // Anyone can read basic videos
      allow write: if false;  // Only admins via Firebase Console
    }

    // Private user data - users can only access their own data
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;

      // Watch history subcollection
      match /watchHistory/{historyId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Admin-only collections (configure admin UIDs in Firebase Console)
    // To make a user admin, add their UID as a document in the admins collection
    match /admins/{adminId} {
      allow read: if false;  // Nobody can read admin list
      allow write: if false;  // Only via Firebase Console
    }
  }
}
